<Window xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:Mesen.ViewModels"
	x:Class="Mesen.Windows.AchievementToastWindow"
	x:DataType="vm:MainWindowViewModel"
	SystemDecorations="None"
	Background="Transparent"
	TransparencyLevelHint="Transparent"
	CanResize="False"
	ShowInTaskbar="False"
	Topmost="True"
	IsHitTestVisible="False"
	SizeToContent="WidthAndHeight"
>
	<Border
		Padding="12 10"
		CornerRadius="8"
		Background="#E61C1C1C"
		BorderBrush="{DynamicResource SystemAccentColor}"
		BorderThickness="1"
		IsHitTestVisible="False"
		Opacity="{Binding AchievementToastOpacity}"
		BoxShadow="0 2 14 0 #90000000"
	>
		<Border.Transitions>
			<Transitions>
				<DoubleTransition Property="Opacity" Duration="0:0:0.3" />
			</Transitions>
		</Border.Transitions>
		<StackPanel Orientation="Horizontal" Spacing="10">
			<Border Width="48" Height="48" CornerRadius="4" ClipToBounds="True">
				<Image Name="BadgeImage" Width="48" Height="48" Stretch="Uniform" />
			</Border>
			<StackPanel VerticalAlignment="Center" Spacing="1">
				<TextBlock Text="Achievement Unlocked" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColor}" />
				<TextBlock Text="{Binding AchievementToastTitle}" FontWeight="SemiBold" Foreground="White" />
				<TextBlock Text="{Binding AchievementToastPoints}" FontSize="11" Foreground="#C0C0C0" />
			</StackPanel>
		</StackPanel>
	</Border>
</Window>
