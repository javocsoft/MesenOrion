<Window
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	x:Class="Mesen.Windows.PrivacyPolicyWindow"
	Width="640" Height="640"
	Title="Privacy Policy"
	Name="root"
>
	<DockPanel Margin="14">
		<TextBlock DockPanel.Dock="Top" Text="Mesen Orion — Privacy Policy" FontSize="17" FontWeight="Bold" Margin="0 0 0 8" />
		<Button DockPanel.Dock="Bottom" Content="Close" HorizontalAlignment="Right" Margin="0 10 0 0" Name="btnClose" />
		<ScrollViewer>
			<SelectableTextBlock Name="txtPolicy" TextWrapping="Wrap" />
		</ScrollViewer>
	</DockPanel>
</Window>
