<Window
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:cfg="using:Mesen.Config"
	xmlns:c="using:Mesen.Controls"
	xmlns:l="using:Mesen.Localization"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	x:Class="Mesen.Windows.RetroAchievementsWindow"
	x:DataType="cfg:RetroAchievementsConfig"
	Width="440"
	SizeToContent="Height"
	CanResize="False"
	Title="RetroAchievements"
	Name="root"
>
	<StackPanel Margin="16" Spacing="10">
		<!-- Title -->
		<StackPanel Orientation="Horizontal" Spacing="8">
			<Image Source="/Assets/Coins.png" Width="20" Height="20" VerticalAlignment="Center" />
			<TextBlock Text="RetroAchievements" FontSize="17" FontWeight="Bold" VerticalAlignment="Center" />
		</StackPanel>

		<!-- Connection status (dot + text) -->
		<StackPanel Orientation="Horizontal" Spacing="6">
			<Ellipse Name="statusDot" Width="9" Height="9" VerticalAlignment="Center" Fill="#888888" />
			<TextBlock Name="lblStatus" VerticalAlignment="Center" TextWrapping="Wrap" />
		</StackPanel>

		<!-- Account section -->
		<c:GroupBox Header="{l:Translate lblAccount}">
			<StackPanel Spacing="5">
				<!-- Login panel (shown when not logged in) -->
				<StackPanel Name="pnlLogin" Spacing="5">
					<TextBlock Text="{l:Translate lblUsername}" />
					<TextBox Name="txtUsername" />
					<TextBlock Text="{l:Translate lblPassword}" Margin="0 4 0 0" />
					<Grid ColumnDefinitions="*,Auto">
						<TextBox Name="txtPassword" PasswordChar="•" />
						<CheckBox Name="chkShow" Grid.Column="1" Content="{l:Translate chkShow}" Margin="6 0 0 0" VerticalAlignment="Center" />
					</Grid>
					<Button Name="btnLogin" Content="{l:Translate btnLogin}" HorizontalAlignment="Right" Margin="0 4 0 0" />
				</StackPanel>

				<!-- Logged-in panel -->
				<Grid Name="pnlLoggedIn" IsVisible="False" ColumnDefinitions="Auto,*,Auto">
					<Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" ClipToBounds="True"
							Background="{DynamicResource ThemeControlMidBrush}" Margin="0 0 10 0">
						<Panel>
							<Image Name="imgAvatarFallback" Source="/Assets/Coins.png" Width="22" Height="22"
								   HorizontalAlignment="Center" VerticalAlignment="Center" />
							<Image Name="imgAvatar" Width="36" Height="36" Stretch="UniformToFill" IsVisible="False" />
						</Panel>
					</Border>
					<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
						<TextBlock Name="lblUser" FontWeight="SemiBold" />
						<TextBlock Name="lblProvider" Text="{l:Translate lblProvider}" FontSize="11"
								   Foreground="{DynamicResource ThemeForegroundLowBrush}" />
					</StackPanel>
					<Button Name="btnLogout" Grid.Column="2" Content="{l:Translate btnLogout}" VerticalAlignment="Center" />
				</Grid>
			</StackPanel>
		</c:GroupBox>

		<!-- Options section -->
		<c:GroupBox Header="{l:Translate lblOptions}">
			<StackPanel Spacing="6">
				<CheckBox Content="{l:Translate chkEnabled}" IsChecked="{Binding Enabled}" />

				<CheckBox Name="chkHardcore" Content="{l:Translate chkHardcore}"
						  ToolTip.Tip="{l:Translate lblHardcoreDesc}" />
				<TextBlock Margin="24 0 0 0" FontSize="11" Foreground="{DynamicResource ThemeForegroundLowBrush}"
						   TextWrapping="Wrap"
						   Text="{l:Translate lblHardcoreDesc}" />
				<Border Name="pnlHardcoreWarning" Margin="24 2 0 0" Padding="8 6" CornerRadius="4"
						Background="{DynamicResource ErrorLowBrush}" IsVisible="{Binding HardcoreMode}">
					<StackPanel Orientation="Horizontal" Spacing="6">
						<Image Source="/Assets/Warning.png" Width="16" Height="16" VerticalAlignment="Top" />
						<TextBlock FontSize="11" TextWrapping="Wrap" MaxWidth="330"
								   Text="{l:Translate lblHardcoreWarning}" />
					</StackPanel>
				</Border>

				<CheckBox Content="{l:Translate chkNotifications}" IsChecked="{Binding EnableNotifications}" />
				<CheckBox Content="{l:Translate chkSound}" IsChecked="{Binding EnableSound}" />
			</StackPanel>
		</c:GroupBox>

		<Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="0 4 0 0">
			<Button Name="btnAchievements" Grid.Column="0" Content="{l:Translate btnViewAchievements}" />
			<Button Name="btnLeaderboards" Grid.Column="1" Margin="6 0 0 0" Content="{l:Translate btnViewLeaderboards}" />
			<Button Name="btnClose" Grid.Column="3" Content="{l:Translate btnClose}" />
		</Grid>
	</StackPanel>
</Window>
