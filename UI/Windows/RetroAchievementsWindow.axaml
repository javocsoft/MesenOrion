<Window
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:cfg="using:Mesen.Config"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	x:Class="Mesen.Windows.RetroAchievementsWindow"
	x:DataType="cfg:RetroAchievementsConfig"
	Width="430"
	SizeToContent="Height"
	CanResize="False"
	Title="RetroAchievements"
	Name="root"
>
	<StackPanel Margin="16" Spacing="10">
		<TextBlock Text="RetroAchievements" FontSize="17" FontWeight="Bold" />
		<TextBlock Name="lblStatus" Opacity="0.8" TextWrapping="Wrap" />

		<!-- Login panel (shown when not logged in) -->
		<StackPanel Name="pnlLogin" Spacing="5">
			<TextBlock Text="Username" />
			<TextBox Name="txtUsername" />
			<TextBlock Text="Password" Margin="0 4 0 0" />
			<Grid ColumnDefinitions="*,Auto">
				<TextBox Name="txtPassword" PasswordChar="•" />
				<CheckBox Name="chkShow" Grid.Column="1" Content="Show" Margin="6 0 0 0" VerticalAlignment="Center" />
			</Grid>
			<Button Name="btnLogin" Content="Log In" HorizontalAlignment="Right" Margin="0 4 0 0" />
		</StackPanel>

		<!-- Logged-in panel -->
		<StackPanel Name="pnlLoggedIn" Spacing="5" IsVisible="False">
			<Button Name="btnLogout" Content="Log Out" HorizontalAlignment="Right" />
		</StackPanel>

		<Separator Margin="0 4" />

		<CheckBox Content="Enable RetroAchievements" IsChecked="{Binding Enabled}" />
		<CheckBox IsChecked="{Binding HardcoreMode}"
				  ToolTip.Tip="Enabling hardcore disables save states, rewind, cheats and speed changes. RetroAchievements approval for Mesen Orion is still pending, so hardcore unlocks are not yet saved on the server.">
			<TextBlock Text="Hardcore mode (disables save states, rewind, cheats and speed changes)" TextWrapping="Wrap" />
		</CheckBox>
		<TextBlock Margin="24 0 0 0" FontSize="11" Opacity="0.7" TextWrapping="Wrap"
				   Text="Note: hardcore approval for this emulator (Mesen Orion) by retroachievements.org is still pending, so hardcore unlocks won't count on the server yet. The hardcore restrictions still apply locally." />
		<CheckBox Content="Show achievement notifications" IsChecked="{Binding EnableNotifications}" />
		<CheckBox Content="Play a sound when an achievement is unlocked" IsChecked="{Binding EnableSound}" />

		<Grid ColumnDefinitions="Auto,*,Auto" Margin="0 6 0 0">
			<Button Name="btnAchievements" Grid.Column="0" Content="View Achievements..." />
			<Button Name="btnClose" Grid.Column="2" Content="Close" />
		</Grid>
	</StackPanel>
</Window>
