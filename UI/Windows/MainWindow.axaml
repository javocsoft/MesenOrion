<Window xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:m="clr-namespace:Mesen"
	xmlns:c="using:Mesen.Controls"
	xmlns:v="using:Mesen.Views"
	xmlns:l="using:Mesen.Localization"
	xmlns:vm="using:Mesen.ViewModels"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DesignWidth="512" d:DesignHeight="505"
	x:Class="Mesen.Windows.MainWindow"
	Width="512" Height="505"
	MinWidth="160" MinHeight="144"
	DragDrop.AllowDrop="True"
	x:DataType="vm:MainWindowViewModel"
	Topmost="{Binding Config.Preferences.AlwaysOnTop}"
	Title="{Binding WindowTitle}"
	Icon="/Assets/mesenorion.ico"
>

	<Design.DataContext>
		<vm:MainWindowViewModel />
	</Design.DataContext>

	<Window.DataTemplates>
		<DataTemplate DataType="{x:Type vm:AudioPlayerViewModel}">
			<v:AudioPlayerView />
		</DataTemplate>
		<DataTemplate DataType="{x:Type vm:RecentGamesViewModel}">
			<c:StateGrid IsVisible="{Binding Visible}" Entries="{Binding GameEntries}" Title="{Binding Title}" Mode="{Binding Mode}" />
		</DataTemplate>
	</Window.DataTemplates>
	
	<DockPanel>
		<Panel DockPanel.Dock="Top" IsVisible="{Binding IsMenuVisible}">
			<Panel DataContext="{Binding MainMenu}">
				<v:MainMenuView Name="MainMenu" />
			</Panel>
		</Panel>
		
		<ContentControl Name="AudioPlayer" DockPanel.Dock="Bottom" Content="{Binding AudioPlayer}" />

		<Border
			DockPanel.Dock="Bottom"
			IsVisible="{Binding IsStatusBarVisible}"
			Background="#202020"
			BorderBrush="#404040"
			BorderThickness="0 1 0 0"
			Padding="6 2"
		>
			<TextBlock Text="{Binding StatusBarText}" Foreground="#D0D0D0" FontSize="11" TextTrimming="CharacterEllipsis" />
		</Border>

		<Panel Name="RendererPanel" Background="Black" Focusable="True">
			<ContentControl Background="#181818" Content="{Binding RecentGames}" IsVisible="{Binding RecentGames.Visible}" />

			<m:NativeRenderer
				Name="Renderer"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				IsVisible="{Binding IsNativeRendererVisible}"
			/>

			<Panel IsVisible="{Binding IsSoftwareRendererVisible}">
				<c:SoftwareRendererView
					Name="SoftwareRenderer"
					DataContext="{Binding SoftwareRenderer}"
					Width="{Binding Width}"
					Height="{Binding Height}"
			  />
			</Panel>

			<!-- RetroAchievements unlock toast (Linux/macOS only: on Windows a separate Topmost
				  window is used from code-behind because NativeControlHost HWNDs always paint
				  above Avalonia Popups) -->
			<Popup
				Name="AchievementToastPopup"
				PlacementTarget="{Binding #RendererPanel}"
				Placement="AnchorAndGravity"
				PlacementAnchor="BottomRight"
				PlacementGravity="TopLeft"
				HorizontalOffset="-16" VerticalOffset="-16"
				IsLightDismissEnabled="False"
				Topmost="True"
				IsOpen="{Binding AchievementToastVisible}"
			>
				<Border
					Padding="12 10"
					CornerRadius="8"
					Background="#E61C1C1C"
					BorderBrush="{DynamicResource SystemAccentColor}"
					BorderThickness="1"
					IsHitTestVisible="False"
					Opacity="{Binding AchievementToastOpacity}"
					BoxShadow="0 2 14 0 #90000000"
				>
					<Border.Transitions>
						<Transitions>
							<DoubleTransition Property="Opacity" Duration="0:0:0.3" />
						</Transitions>
					</Border.Transitions>
					<StackPanel Orientation="Horizontal" Spacing="10">
						<Border Width="48" Height="48" CornerRadius="4" ClipToBounds="True">
							<Image Source="{Binding AchievementToastBadge}" Width="48" Height="48" Stretch="Uniform" />
						</Border>
						<StackPanel VerticalAlignment="Center" Spacing="1">
							<TextBlock Text="Achievement Unlocked" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColor}" />
							<TextBlock Text="{Binding AchievementToastTitle}" FontWeight="SemiBold" Foreground="White" />
							<TextBlock Text="{Binding AchievementToastPoints}" FontSize="11" Foreground="#C0C0C0" />
						</StackPanel>
					</StackPanel>
				</Border>
			</Popup>
		</Panel>
	</DockPanel>
</Window>
