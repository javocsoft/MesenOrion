<Window
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:m="clr-namespace:Mesen"
	xmlns:c="using:Mesen.Controls"
	xmlns:i="using:Mesen.Interop"
	xmlns:cfg="using:Mesen.Config"
	xmlns:vm="using:Mesen.ViewModels"
	xmlns:l="using:Mesen.Localization"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="150"
	x:Class="Mesen.Windows.NetplayStartServerWindow"
	Width="380" SizeToContent="Height"
	x:DataType="cfg:NetplayConfig"
	Title="{l:Translate wndTitle}"
>
	<DockPanel Margin="5">
		<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
			<Button MinWidth="70" HorizontalContentAlignment="Center" Click="Ok_OnClick" Content="{l:Translate btnOK}" />
			<Button MinWidth="70" HorizontalContentAlignment="Center" IsCancel="True" Click="Cancel_OnClick" Content="{l:Translate btnCancel}" />
		</StackPanel>

		<Grid ColumnDefinitions="Auto,1*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" VerticalAlignment="Top">
			<TextBlock Text="{l:Translate lblPort}" VerticalAlignment="Center" Margin="0 3" />
			<c:MesenNumericTextBox Grid.Column="1" Grid.ColumnSpan="2" Value="{Binding ServerPort}" Min="1" Max="65535" Margin="0 3" />

			<TextBlock Grid.Row="1" Text="{l:Translate lblPassword}" VerticalAlignment="Center" Margin="0 3 5 3" />
			<TextBox
				Name="PasswordBox"
				Grid.Row="1" Grid.Column="1"
				Margin="0 3"
				PasswordChar="*"
				RevealPassword="{Binding #EyeToggle.IsChecked}"
				Text="{Binding ServerPassword, Converter={StaticResource NullTextConverter}}"
			/>
			<StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="3 3 0 3">
				<ToggleButton Name="EyeToggle" IsThreeState="False"
					ToolTip.Tip="{l:Translate lblShowHidePassword}"
					AutomationProperties.Name="{l:Translate lblShowHidePassword}"
					Padding="5 2" VerticalAlignment="Stretch">
					<Panel Width="16" Height="12">
						<Ellipse Width="15" Height="9" StrokeThickness="1.3"
							Stroke="{Binding $parent[ToggleButton].Foreground}"
							HorizontalAlignment="Center" VerticalAlignment="Center" />
						<Ellipse Width="5" Height="5"
							Fill="{Binding $parent[ToggleButton].Foreground}"
							HorizontalAlignment="Center" VerticalAlignment="Center" />
					</Panel>
				</ToggleButton>
				<Button Click="CopyPassword_OnClick"
					ToolTip.Tip="{l:Translate lblCopy}"
					AutomationProperties.Name="{l:Translate lblCopy}"
					Padding="5 2" Margin="3 0 0 0" VerticalAlignment="Stretch">
					<Image Source="/Assets/Copy.png" Width="16" Height="16" Stretch="Uniform" />
				</Button>
			</StackPanel>

			<TextBlock Grid.Row="2" Text="{l:Translate lblYourIp}" VerticalAlignment="Center" Margin="0 3 5 3" />
			<TextBox Name="IpBox" Grid.Row="2" Grid.Column="1" Margin="0 3" IsReadOnly="True" />
			<Button Grid.Row="2" Grid.Column="2" Click="CopyIp_OnClick"
				ToolTip.Tip="{l:Translate lblCopy}"
				AutomationProperties.Name="{l:Translate lblCopy}"
				Padding="5 2" Margin="3 3 0 3" VerticalAlignment="Stretch">
				<Image Source="/Assets/Copy.png" Width="16" Height="16" Stretch="Uniform" />
			</Button>

			<TextBlock Grid.Row="3" Text="{l:Translate lblPublicIp}" VerticalAlignment="Center" Margin="0 3 5 3" />
			<TextBox Name="PublicIpBox" Grid.Row="3" Grid.Column="1" Margin="0 3" IsReadOnly="True" />
			<StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal" Margin="3 3 0 3">
				<Button Name="GetPublicIpButton" Click="GetPublicIp_OnClick" Content="{l:Translate btnGetPublicIp}"
					AutomationProperties.Name="{l:Translate lblPublicIp}"
					Padding="5 2" VerticalAlignment="Stretch" />
				<Button Click="CopyPublicIp_OnClick"
					ToolTip.Tip="{l:Translate lblCopy}"
					AutomationProperties.Name="{l:Translate lblCopy}"
					Padding="5 2" Margin="3 0 0 0" VerticalAlignment="Stretch">
					<Image Source="/Assets/Copy.png" Width="16" Height="16" Stretch="Uniform" />
				</Button>
			</StackPanel>

			<TextBlock Grid.Row="4" Grid.ColumnSpan="3" Text="{l:Translate lblOpenPortHint}"
				TextWrapping="Wrap" Foreground="Gray" Margin="0 6 0 0" />
		</Grid>
	</DockPanel>
</Window>
