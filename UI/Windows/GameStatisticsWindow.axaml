<Window
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:w="using:Mesen.Windows"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	x:Class="Mesen.Windows.GameStatisticsWindow"
	Width="500" Height="560"
	Title="Game Statistics"
	Name="root"
>
	<DockPanel Margin="12">
		<Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0 0 0 10">
			<StackPanel Grid.Column="0" Spacing="1">
				<TextBlock Text="Game Statistics" FontSize="16" FontWeight="Bold" />
				<TextBlock Name="lblSummary" Opacity="0.7" FontSize="12" />
			</StackPanel>
			<Button Name="btnClear" Grid.Column="1" Content="Clear All" VerticalAlignment="Center" />
		</Grid>

		<Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="4 0 16 4">
			<TextBlock Grid.Column="0" Text="Game" FontWeight="Bold" FontSize="11" Opacity="0.7" />
			<TextBlock Grid.Column="1" Text="Playtime" FontWeight="Bold" FontSize="11" Opacity="0.7" Width="90" />
			<TextBlock Grid.Column="2" Text="Last played" FontWeight="Bold" FontSize="11" Opacity="0.7" Width="110" />
		</Grid>

		<TextBlock Name="lblEmpty" Text="No play data yet. Play a game and it'll show up here."
				   Opacity="0.6" TextWrapping="Wrap" IsVisible="False" />

		<ScrollViewer>
			<ItemsControl Name="lstStats">
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="w:GameStatRow">
						<Border Padding="4 6" Margin="0 0 0 2" CornerRadius="4"
								Background="{DynamicResource ThemeControlLowBrush}">
							<Grid ColumnDefinitions="*,Auto,Auto">
								<TextBlock Grid.Column="0" Text="{Binding Name}" TextTrimming="CharacterEllipsis"
										   VerticalAlignment="Center" Margin="4 0 8 0" />
								<TextBlock Grid.Column="1" Text="{Binding PlaytimeText}" Width="90"
										   VerticalAlignment="Center" FontWeight="SemiBold" />
								<TextBlock Grid.Column="2" Text="{Binding LastPlayedText}" Width="110"
										   VerticalAlignment="Center" Opacity="0.8" />
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</DockPanel>
</Window>
